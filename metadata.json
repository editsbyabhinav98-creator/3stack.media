{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A media project in the 3Stack portfolio.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "title": { "type": "string", "description": "Project title" },
        "type": { "type": "string", "description": "Media type (e.g., video)" },
        "url": { "type": "string", "description": "URL to the media asset" },
        "size": { "type": "string", "description": "Bento grid size (small, medium, large)" },
        "description": { "type": "string", "description": "AI-generated case study description" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "authorUid": { "type": "string", "description": "UID of the creator" }
      },
      "required": ["id", "title", "url", "createdAt", "authorUid"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "viewer"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Reel": {
      "title": "Reel",
      "description": "A vertical reel-form video.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "url", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A client review/testimonial.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pfp": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "pfp", "text", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of media projects."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and role data."
    },
    "/reels/{reelId}": {
      "schema": "Reel",
      "description": "Collection of vertical reel videos."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of client reviews."
    }
  }
}
