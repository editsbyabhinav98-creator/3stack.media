rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
        (request.auth.uid == "WOwtjvJtgUWCKNSTYAfrYPx6iN33" || 
         request.auth.token.email == "editsbyabhinav98@gmail.com" ||
         request.auth.token.email == "maharakhlesh38@gmail.com");
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
    }

    match /reels/{reelId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
